NEXT_PUBLIC_ALGOLIA_APP_ID=
NEXT_PUBLIC_ALGOLIA_INDEX_NAME=
NEXT_PUBLIC_ALGOLIA_SEARCH_API_KEY=

# ── Hetzner VPS Scan Worker ──────────────────────────────────────────────────
# Shared secret sent by the VPS in the x-webhook-secret header.
GCP_WEBHOOK_SECRET=

# API key used by /api/scan/dispatch to authenticate with the Hetzner worker.
SCANNER_API_KEY=

# Base URL of the Hetzner VPS API (defaults to https://api.vulnscanners.com).
SCANNER_API_URL=https://api.vulnscanners.com

# ── Firebase Admin (server-side only) ───────────────────────────────────────
# Required for the webhook endpoint to write to Firestore.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste the private key exactly as it appears in the service account JSON.
# Replace literal newlines with \n — Vercel handles this automatically.
FIREBASE_PRIVATE_KEY=