NEXT_PUBLIC_ALGOLIA_APP_ID=
NEXT_PUBLIC_ALGOLIA_INDEX_NAME=
NEXT_PUBLIC_ALGOLIA_SEARCH_API_KEY=

# ── Firebase ────────────────────────────────────────────────────────────────
# Public project identifier (safe to commit).
NEXT_PUBLIC_FIREBASE_PROJECT_ID=

# Service-account credentials for Firebase Admin SDK.
# Paste the *entire* JSON object (minified) as a single-line string value.
# Keep this secret — never commit a real value here.
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── Scan worker ─────────────────────────────────────────────────────────────
# Shared secret used in both directions between Next.js and the Hetzner worker:
#   Next.js → Hetzner:  X-Scanner-Token: <GCP_WEBHOOK_SECRET>
#   Hetzner → Next.js:  x-webhook-secret: <GCP_WEBHOOK_SECRET>
GCP_WEBHOOK_SECRET=